# ─── Guesty Open API (secrets del servidor — Supabase / Edge Function) ───
# Se generan en Guesty: Integrations → API & Webhooks → Create New Application (requiere admin)
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# ─── Supabase (servidor) ───
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=       # solo backend / Edge Function — NUNCA en el cliente

# ─── Next.js (cliente — solo estas dos, son públicas por diseño) ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
